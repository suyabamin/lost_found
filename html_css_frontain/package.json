{
  "name": "lost-found-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dev-server.js",
    "dev": "node dev-server.js",
    "dev:full": "npm run clean; start /B node dev-server.js; start /B npm run backend; cd frontend && npm run dev",
    "backend": "cd backend && npm start",
    "clean": "Stop-Process -Id (Get-NetTCPConnection -LocalPort 8000).OwningProcess -ErrorAction SilentlyContinue",
    "restart": "npm run clean; npm start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.7"
  }
}
